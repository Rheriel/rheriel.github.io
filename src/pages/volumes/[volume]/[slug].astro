---
import { getCollection, render } from 'astro:content';
import HandbookSidebar from '../../../components/HandbookSidebar.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const concepts = await getCollection('concepts');
  return concepts.map((concept) => ({
    params: {
      volume: concept.data.volume,
      slug: concept.slug
    },
    props: { concept }
  }));
}

const { concept } = Astro.props;
const { Content } = await render(concept);
const volume = (await getCollection('volumes')).find((entry) => entry.slug === concept.data.volume);
---

<BaseLayout title={concept.data.title} description={concept.data.summary}>
  <Fragment slot="sidebar">
    <HandbookSidebar currentVolume={concept.data.volume} currentConcept={concept.slug} />
  </Fragment>

  <article class="prose">
    <p class="eyebrow">{volume?.data.title ?? 'Handbook concept'}</p>
    <h1>{concept.data.title}</h1>
    <p class="meta">Level: {concept.data.level}</p>
    <Content />
  </article>
</BaseLayout>
