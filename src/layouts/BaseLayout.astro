---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site and writing by Ban Finch.' } = Astro.props;
const siteTitle = 'Ban Finch';
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const hasSidebar = Astro.slots.has('sidebar');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="identity" href="/" aria-label="Ban Finch home">
          <span class="avatar" aria-hidden="true">BF</span>
          <span class="brand">Ban Finch</span>
        </a>
        <span class="header-separator" aria-hidden="true"></span>
        <nav class="primary-nav" aria-label="Primary">
          <a href="/about/">About Me</a>
          <a href="/blog/">Blog</a>
          <a href="/writing/">Writing</a>
          <a href="/volumes/04-concurrency/">Handbook: Volume 4</a>
        </nav>
      </header>
      <div class="page-grid">
        {hasSidebar && (
          <aside class="sidebar" aria-label="Context">
            <slot name="sidebar" />
          </aside>
        )}
        <main>
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
