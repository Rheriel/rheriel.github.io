---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A practical interview guide for working engineers.' } = Astro.props;
const pageTitle = title === "The Busy Engineer's Interview Handbook"
  ? title
  : `${title} | The Busy Engineer's Interview Handbook`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">The Busy Engineer</a>
      <nav aria-label="Primary">
        <a href="/volumes/01-core-backend-concepts/">Volume 1</a>
        <a href="/volumes/01-core-backend-concepts/transactions/">Transactions</a>
        <a href="/volumes/01-core-backend-concepts/acid/">ACID</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
